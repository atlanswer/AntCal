{
  "name": "@antcal/web",
  "version": "0.31.6",
  "description": "Generate publication quality figures",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://antcal.atlanswer.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atlanswer/AntCal.git"
  },
  "bugs": {
    "url": "https://github.com/atlanswer/AntCal/issues"
  },
  "scripts": {
    "dev": "bun astro dev --open",
    "check": "bun astro check",
    "build": "bun astro build",
    "preview": "bun astro preview"
  },
  "prettier": {
    "experimentalTernaries": true,
    "experimentalOperatorPosition": "start",
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ],
    "tailwindStylesheet": "./src/styles/global.css"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7-beta.1",
    "@astrojs/solid-js": "^6.0.0-beta.2",
    "@astrojs/ts-plugin": "^1.10.6",
    "@solidjs/meta": "^0.29.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/d3": "^7.4.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^6.0.0-beta.18",
    "d3": "^7.9.0",
    "d3-3d": "^2.0.2",
    "geist": "^1.7.0",
    "katex": "^0.16.28",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "solid-js": "^1.9.11",
    "tailwindcss": "^4.2.1",
    "valibot": "^1.2.0"
  }
}
