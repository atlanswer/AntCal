{
  "extends": ["astro/tsconfigs/strictest"],
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "~/*": ["./*"],
      "~/public/*": ["./public/*"],
      "~/src/*": ["./src/*"],
      "~/components/*": ["./src/components/*"],
      "~/layouts/*": ["./src/layouts/*"],
      "~/styles/*": ["./src/styles/*"]
    },
    "plugins": [{ "name": "@astrojs/ts-plugin" }]
  }
}
